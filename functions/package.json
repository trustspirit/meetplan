{
  "name": "functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=lib/index.js --external:firebase-admin --external:firebase-admin/* --external:firebase-functions --external:firebase-functions/*",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.1.1"
  },
  "devDependencies": {
    "@meetplan/shared": "workspace:*",
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
