rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() { return request.auth != null; }
    function isEventHost(eventId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isAuthed()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.slots == resource.data.slots;
      allow delete: if false;

      match /responses/{responseId} {
        allow get:   if isEventHost(eventId)
                      || (isAuthed() && resource.data.ownerUid == request.auth.uid);
        allow list:  if isEventHost(eventId);
        allow write: if false;
      }
    }
  }
}
